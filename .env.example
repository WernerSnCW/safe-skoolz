# Database (Postgres). Set automatically by Replit for the dev container.
DATABASE_URL=postgres://user:pass@localhost:5432/safeskoolz

# JWT signing for session tokens.
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1h

# Node mode. Set to "production" in deployments; anything else is treated as dev.
NODE_ENV=development

# CORS allowlist. Comma-separated absolute origins (no trailing slash). In non-production
# this list is automatically extended with localhost:* and *.replit.dev so the dev
# workflow and Replit preview iframes work without per-branch configuration.
CORS_ALLOWED_ORIGINS=https://app.safeskoolz.com,https://safeskoolz.com

# Resend (transactional email). When unset, sendEmail() is a no-op (see T06 boot check).
RESEND_API_KEY=

# OpenAI (used by AI escalation summarisation paths).
OPENAI_API_KEY=

# Background jobs (pattern scan etc). Set to "false" in workers that should not run cron.
JOBS_ENABLED=true

# Absolute URL where the safeschool web app is served. Used to build password-reset links.
APP_URL=http://localhost:5000

# MFA (TOTP) — T11. Base64-encoded 32-byte key for encrypting TOTP secrets at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MFA_ENC_KEY=
# Set to "true" to force MFA on coordinator + head_teacher logins when they have MFA enabled.
MFA_ENFORCED=false
